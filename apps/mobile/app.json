{
  "expo": {
    "name": "ReeL-Trip",
    "slug": "reel-trip",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "reeltrip",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.reeltrip.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.reeltrip.app"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
